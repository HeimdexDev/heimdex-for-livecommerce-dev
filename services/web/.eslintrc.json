{
  "extends": ["next/core-web-vitals"],
  "overrides": [
    {
      "files": ["src/features/shorts-auto/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": [
                  "@/features/shorts-editor/*",
                  "@/features/shorts/*",
                  "@/features/people/*",
                  "@/features/videos/*",
                  "@/features/basket/*",
                  "@/features/blur/*",
                  "@/features/preedit/*",
                  "@/features/search/*",
                  "@/features/settings/*",
                  "@/features/folders/*",
                  "@/features/devices/*",
                  "@/features/images/*"
                ],
                "message": "features/shorts-auto must not import from other feature directories. Use lib/api, lib/types, or components/ for shared code. See .claude/plans/auto-shorts-v1.md §7.5."
              }
            ]
          }
        ]
      }
    }
  ]
}
